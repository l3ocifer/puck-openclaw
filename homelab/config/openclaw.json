{
  // OpenClaw config for Puck — creative agent. Poems, books, videos,
  // music. Floats; soft-prefers thebeast for RAM. Internal-facing
  // (Frack publishes anything that goes to the world).

  models: {
    mode: "merge",
    providers: {
      litellm: {
        baseUrl: "http://litellm.inference.svc.cluster.local:4000/v1",
        apiKeyEnv: "LITELLM_API_KEY",
        api: "openai-completions",
        models: [
          {
            id: "chat",
            name: "Default conversational + drafting",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 131072,
            maxTokens: 8192,
          },
          {
            id: "code",
            name: "Skills/scripting",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 8192,
          },
          {
            id: "long",
            name: "Book-length context (full manuscript)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 1000000,
            maxTokens: 16384,
          },
          {
            id: "frontier",
            name: "Careful prose — limited budget",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 200000,
            maxTokens: 8192,
          },
          {
            id: "embed",
            name: "Embeddings for portfolio search",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 8192,
            maxTokens: 0,
          },
          {
            id: "tts",
            name: "Text-to-speech",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 4096,
            maxTokens: 0,
          },
          {
            id: "transcribe",
            name: "Whisper transcription",
            reasoning: false,
            input: ["audio"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 0,
            maxTokens: 0,
          },
          {
            id: "image",
            name: "Image generation",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 4096,
            maxTokens: 0,
          }
        ]
      }
    }
  },

  agents: {
    defaults: {
      model: {
        primary:   "litellm/chat",
        fallbacks: ["litellm/long", "litellm/frontier"],
      },
      workspace: "/root/.openclaw/workspace",
      compaction: { mode: "safeguard" },
      contextPruning: { mode: "cache-ttl", ttl: "2h" },
      maxConcurrent: 4,
      thinkingDefault: "low",
      heartbeat: {
        every: "30m",
        offsetMinutes: 25,
        target: "https://hc-ping.com/puck-${HEALTHCHECKS_UUID}",
      },
      memorySearch: {
        enabled: true,
        sources: ["memory", "sessions"],
        extraPaths: [
          "/data/graphs/puck/pages",
          "/data/graphs/puck/journals",
          "/data/graphs/leo/pages",
          "/data/graphs/leo/journals",
          "/data/graphs/frick/pages",
          "/data/graphs/frack/pages",
          "/data/graphs/sancho/pages",
          "/data/graphs/vetinari/pages",
          "/data/graphs/quirm/pages",
          "/data/graphs/vimes/pages",
        ],
        provider: "litellm",
        litellm: {
          embedModel: "embed",
        },
        fallback: "local",
        local: {
          modelPath: "hf:ggml-org/embeddinggemma-300M-GGUF/embeddinggemma-300M-Q8_0.gguf",
        },
        store: {
          backend: "postgres-pgvector",
          urlEnv: "DATABASE_URL",
          schema: "puck_memory",
        },
        sync: {
          watch: true,
          watchDebounceMs: 2000,
          onSessionStart: true,
          onSearch: true,
        },
        query: {
          hybrid: {
            enabled: true,
            vectorWeight: 0.7,
            textWeight: 0.3,
          },
        },
      },
    },
    list: [
      {
        id: "main",
        default: true,
        identity: {
          name: "Puck",
          theme: "creative — poems, books, videos, music",
          emoji: "🎭",
        },
      }
    ],
  },

  tools: {
    profile: "creative",
    allow: ["read", "write", "edit", "exec", "web_search", "browser"],
    exec: {
      host: "gateway",
      ask: "off",
      security: "sandboxed",
      // Allowlist enforced at gateway. Filesystem writes confined to
      // /workspace/ and /data/graphs/puck/. No kubectl mutations.
      allowedCommands: [
        "ffmpeg", "ffprobe",
        "convert", "mogrify", "identify",     // imagemagick
        "pandoc",
        "yt-dlp",
        "calibre", "ebook-convert",
        "git",                                // own working trees only
        "kubectl get", "kubectl describe",
        "psql -c", "psql -tAc",
        "rg", "jq",
      ],
    },
    elevated: {
      enabled: false,
    },
    confirm: [
      "external_post",
      "external_email",
      "github_push",
      "github_pr_merge",
      // Frack handles publication. Anything Puck attempts that
      // touches outward channels is flagged for confirmation.
    ],
  },

  skills: {
    load: {
      extraDirs: ["/data/graphs/puck/pages/skills"],
    },
  },

  gateway: {
    mode: "headless",
    port: 18789,
    bind: "0.0.0.0",
  },

  channels: {
    matrix: {
      enabled: true,
      homeserver: "https://conduit.leopaska.xyz",
      userId: "@puck:leopaska.xyz",
      accessTokenEnv: "MATRIX_ACCESS_TOKEN",
      defaultRoom: "!homelab:leopaska.xyz",
    },
    telegram: {
      enabled: true,
      botTokenEnv: "TELEGRAM_BOT_TOKEN",
      prefix: "/puck",
    },
    ntfy: {
      enabled: true,
      outboundOnly: true,
      topicUrl: "https://ntfy.leopaska.xyz/puck",
      bearerTokenEnv: "NTFY_TOKEN",
    },
    // No iMessage, no BlueBubbles, no Stripe — Puck is internal-only.
  },

  hardKill: {
    sentinelPath: "/data/HARDSTOP-PUCK",
    pollIntervalSeconds: 30,
    onTrigger: "graceful_exit",
  },

  quietHours: {
    enabled: true,
    window: "22:00-06:30",
    timezone: "America/New_York",
    suppressOutbound: ["telegram", "ntfy"],
    allowOutboundOnP0: true,
    allowInboundAlways: true,
  },

  a2a: {
    listenBind: "0.0.0.0:50052",
    sharedSecretEnv: "OFP_SHARED_SECRET",
    peers: [
      { id: "frick",    url: "http://frick.agents-shared.svc:3000" },
      { id: "frack",    url: "http://frack.agents-shared.svc:18789" },
      { id: "sancho",   url: "http://sancho.agents-shared.svc:3001" },
      { id: "vetinari", url: "http://vetinari.agents-shared.svc:4200" },
      { id: "quirm",    url: "http://quirm.agents-shared.svc:3001" },
      { id: "vimes",    url: "http://vimes.agents-shared.svc:3000" }
    ]
  },

  // Fleet event bus — durable async A2A backbone shared by all
  // seven agents. Backed by Postgres LISTEN/NOTIFY on the `fleet` DB.
  fleet: {
    enabled: true,
    agentId: "puck",
    databaseUrlEnv: "FLEET_DATABASE_URL",
    notifyChannel: "fleet_events_new",
    inbound: {
      // Puck only wakes for things explicitly pinged at the creative
      // surface or all-broadcast P0s.
      predicate: "severity = 'p0' OR target IS NULL OR target = 'puck' OR kind LIKE 'creative.%'",
    },
  },

  cron: [
    {
      schedule: "30 6 * * *",
      prompt: "Compose and send the daily creative briefing to Leo via Matrix: what's in flight (top 3 from puck-graph/pages/in-progress/), what shipped yesterday (from portfolio/), and one pull for today. Save the briefing to puck-graph/pages/briefings/."
    },
    {
      schedule: "0 18 * * 0",
      prompt: "Weekly portfolio review. Inventory new finished pieces from the past 7 days. Move cold drafts (>30 days untouched) to archive-staging. Regenerate portfolio/INDEX.md. Push archive-staging to MinIO bucket `puck-archive`. Save a one-page review memo to puck-graph/pages/methodology/ summarizing what kind of work got finished, what got abandoned, and any patterns worth noting."
    }
  ],
}
